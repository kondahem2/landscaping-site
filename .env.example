# Copy this file to `.env` and put your real secrets there.
# The app loads `.env` — NOT `.env.example` — so values only in `.env.example` are ignored
# unless you have no `.env` file (then .env.example is loaded as a fallback with a warning).

PORT=3000

# Required for admin sessions (use a long random string in production)
SESSION_SECRET=replace-with-random-string

# Admin password — use ONE of these:
# Option A: plain password (hashed in memory on each server start — easy to change)
ADMIN_PASSWORD=change-this-password

# Option B (production): bcrypt hash from: npm run hash-password -- "your-password"
# ADMIN_PASSWORD_HASH=$2a$10$...

# --- Quote form → email notifications (optional) ---
# Must live in THIS FILE (.env), not only in .env.example — restart the server after editing.
#
# Where to send new lead details (comma-separated for multiple inboxes)
# LEAD_EMAIL_TO=you@example.com

# SMTP — Gmail, Outlook, SendGrid SMTP, Mailgun, your host, etc.
# Gmail: use an App Password (Google Account → Security → 2-Step → App passwords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-app-password

# Port 465: set SMTP_SECURE=true. Port 587: SMTP_SECURE=false (STARTTLS).
# Optional: From header (defaults to "Harmeet Landscaping <SMTP_USER>")
# LEAD_EMAIL_FROM="Harmeet Landscaping <quotes@yourdomain.com>"

# Set to true to save leads to disk but skip sending email
# LEAD_EMAIL_DISABLED=false

# Debug: verify SMTP on server startup (logs OK or error)
# SMTP_VERIFY_ON_START=false

# Rare: force STARTTLS on port 587 if your host requires it
# SMTP_REQUIRE_TLS=false
