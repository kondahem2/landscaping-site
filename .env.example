# Copy this file to `.env` and put your real secrets there.
# The app loads `.env` — NOT `.env.example` — so values only in `.env.example` are ignored
# unless you have no `.env` file (then .env.example is loaded as a fallback with a warning).

PORT=3000

# Required for admin sessions (use a long random string in production)
SESSION_SECRET=replace-with-random-string

# Admin password — use ONE of these:
# Option A: plain password (hashed in memory on each server start — easy to change)
ADMIN_PASSWORD=change-this-password

# Option B (production): bcrypt hash from: npm run hash-password -- "your-password"
# ADMIN_PASSWORD_HASH=$2a$10$...
